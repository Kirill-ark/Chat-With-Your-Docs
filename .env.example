# Copy this file to .env and fill in your real key. NEVER commit the real .env.
# On deploy (Streamlit Cloud / HF Spaces) set these as hosting secrets instead.

# Groq API key (free tier: console.groq.com -> API Keys)
GROQ_API_KEY=your_key_here

# Optional: override the default LLM model name
# LLM_MODEL=llama-3.1-8b-instant
